# ─── Claude AI ────────────────────────────────────────────────
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-xxxx

# ─── 네이버 블로그 ──────────────────────────────────────────
# 네이버 블로그 ID (예: blog.naver.com/YOUR_ID 에서 YOUR_ID 부분)
NAVER_BLOG_ID=your_naver_id

# 네이버 로그인 계정 (블로그 소유 계정)
NAVER_USERNAME=your_naver_id
NAVER_PASSWORD=your_password

# ─── 네이버 Open API ──────────────────────────────────────────
# https://developers.naver.com 에서 발급 (DataLab 트렌드 검색용)
NAVER_CLIENT_ID=your_client_id
NAVER_CLIENT_SECRET=your_client_secret

# ─── Pexels 이미지 API (선택사항) ────────────────────────────
# https://www.pexels.com/api/ 에서 무료 발급
PEXELS_API_KEY=your_pexels_key

# ─── 포스팅 설정 ──────────────────────────────────────────────
# draft = 임시저장 (기본값, 안전)
# publish = 바로 발행
POST_STATUS=draft

# 블로그에 미리 만들어 둔 카테고리 이름 (없으면 "기본" 사용)
POST_CATEGORY=금융

# false = 브라우저 창 보이며 실행 (첫 로그인 시 필요)
# true  = 백그라운드(화면 없이) 실행
HEADLESS=false
